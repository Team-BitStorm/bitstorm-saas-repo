# Django API base URL (no trailing slash)
#
# Local: copy to `.env` or `.env.local`
#   VITE_API_BASE_URL=http://localhost:8000
#
# Production: `.env.production` (or set in your host's build env vars)
#   VITE_API_BASE_URL=https://bitstorm-saas-repo.onrender.com

VITE_API_BASE_URL=http://localhost:8000
